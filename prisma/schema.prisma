generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String?
  telefone  String?
  cpf       String?  @unique
  role      String   @default("customer")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders        Order[]
  subscriptions Subscription[]
}

model Product {
  id        Int     @id @default(autoincrement())
  nome      String
  descricao String?
  preco     Float
  imagem    String?
  categoria String?
  estoque   Int     @default(0)
  ativo     Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]
}

model Order {
  id              Int      @id @default(autoincrement())
  userId          Int?
  total           Float
  status          String   @default("pending")
  mpPaymentId     String?
  nomeCliente     String?
  emailCliente    String?
  telefoneCliente String?
  cpfCliente      String?
  endereco        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User?       @relation(fields: [userId], references: [id])
  items OrderItem[]
}

model OrderItem {
  id         Int   @id @default(autoincrement())
  orderId    Int
  productId  Int
  quantidade Int
  preco      Float

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Subscription {
  id           Int       @id @default(autoincrement())
  userId       Int?
  status       String    @default("pending")
  plano        String    @default("mensal")
  valor        Float     @default(49.90)
  mpSubId      String?
  dataInicio   DateTime  @default(now())
  dataFim      DateTime?
  nomeCliente  String?
  emailCliente String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

model Admin {
  id    Int    @id @default(autoincrement())
  email String @unique
  senha String
  nome  String
}
